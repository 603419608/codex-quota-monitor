<Window x:Class="CodexUsageOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CodexUsageOverlay.App"
        Title="Codex Quota Monitor"
        Width="230"
        Height="520"
        MinWidth="220"
        MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#F0151515" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="TextBrush" Color="#F2F2F2" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A9A9A9" />
        <SolidColorBrush x:Key="SubtleSeparatorBrush" Color="#303030" />
        <SolidColorBrush x:Key="TrackBrush" Color="#313131" />

        <Style x:Key="TransparentIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#5F5F5F" />
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GaugeTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GaugeResetText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GaugePrimaryText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="17" />
        </Style>

        <Style x:Key="GaugeDetailText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Visibility="{Binding FullPanelVisibility}"
                MouseLeftButtonDown="WindowDragArea_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="28" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1"
                        Content="−"
                        Width="24"
                        Height="24"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="{StaticResource MutedTextBrush}"
                        Click="CollapseButton_Click" />
                <Button Grid.Column="2"
                        Content="●"
                        Width="24"
                        Height="24"
                        Padding="0"
                        FontSize="10"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="{StaticResource MutedTextBrush}"
                        ToolTip="{Binding HideToTrayText}"
                        Click="HideToTrayButton_Click" />
                <Button Grid.Column="3"
                        Content="×"
                        Width="24"
                        Height="24"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="{StaticResource MutedTextBrush}"
                        Click="CloseButton_Click" />
            </Grid>

            <StackPanel Grid.Row="1"
                        Margin="0,10,0,4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <StackPanel Width="180"
                            Margin="0,0,0,14"
                            HorizontalAlignment="Center"
                            Visibility="{Binding AccountSummaryVisibility}">
                    <TextBlock Text="{Binding AccountNameText}"
                               ToolTip="{Binding AccountNameText}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding LifetimeTokensText}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="11"
                               TextAlignment="Center" />
                    <Border Height="1"
                            Background="{StaticResource SubtleSeparatorBrush}"
                            Margin="8,9,8,0" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Center"
                            Margin="0,0,0,18">
                    <TextBlock Text="{Binding ContextTitle}"
                               Style="{StaticResource GaugeTitle}" />
                    <Grid Width="98"
                          Height="98"
                          Margin="0,5,0,0">
                        <local:CircularGauge Value="{Binding ContextRingValue}"
                                             Stroke="{Binding ContextRingBrush}"
                                             Track="{StaticResource TrackBrush}"
                                             StrokeThickness="8" />
                        <StackPanel VerticalAlignment="Center"
                                    Margin="12,0">
                            <TextBlock Text="{Binding ContextGaugeText}"
                                       Style="{StaticResource GaugePrimaryText}" />
                            <TextBlock Text="{Binding ContextGaugeDetailText}"
                                       Style="{StaticResource GaugeDetailText}"
                                       MaxWidth="78" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center"
                            Margin="0,0,0,18"
                            Visibility="{Binding FiveHourLimitVisibility}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="{Binding FiveHourTitle}"
                                   Style="{StaticResource GaugeTitle}" />
                        <TextBlock Text="{Binding FiveHourResetText}"
                                   Style="{StaticResource GaugeResetText}"
                                   Visibility="{Binding FiveHourResetVisibility}" />
                    </StackPanel>
                    <Grid Width="98"
                          Height="98"
                          Margin="0,5,0,0">
                        <local:CircularGauge Value="{Binding FiveHourValue}"
                                             Stroke="{Binding FiveHourRingBrush}"
                                             Track="{StaticResource TrackBrush}"
                                             StrokeThickness="8" />
                        <StackPanel VerticalAlignment="Center"
                                    Margin="12,0">
                            <TextBlock Text="{Binding FiveHourGaugeText}"
                                       Style="{StaticResource GaugePrimaryText}" />
                            <TextBlock Text="{Binding RemainingLabel}"
                                       Style="{StaticResource GaugeDetailText}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="{Binding WeeklyTitle}"
                                   Style="{StaticResource GaugeTitle}" />
                        <TextBlock Text="{Binding WeeklyResetText}"
                                   Style="{StaticResource GaugeResetText}"
                                   Visibility="{Binding WeeklyResetVisibility}" />
                    </StackPanel>
                    <Grid Width="98"
                          Height="98"
                          Margin="0,5,0,0">
                        <local:CircularGauge Value="{Binding WeeklyValue}"
                                             Stroke="{Binding WeeklyRingBrush}"
                                             Track="{StaticResource TrackBrush}"
                                             StrokeThickness="8" />
                        <StackPanel VerticalAlignment="Center"
                                    Margin="12,0">
                            <TextBlock Text="{Binding WeeklyGaugeText}"
                                       Style="{StaticResource GaugePrimaryText}" />
                            <TextBlock Text="{Binding RemainingLabel}"
                                       Style="{StaticResource GaugeDetailText}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Visibility="{Binding ResetCreditsVisibility}"
                            Margin="0,14,0,0"
                            Width="180">
                    <Border Height="1"
                            Background="{StaticResource SubtleSeparatorBrush}"
                            Margin="8,0,8,8" />
                    <Grid ToolTip="{Binding ResetCreditsTooltipText}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="22" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ResetCreditsSummaryText}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   MaxWidth="148" />
                        <Button Grid.Column="1"
                                Style="{StaticResource TransparentIconButton}"
                                Content="↻"
                                Width="20"
                                Height="20"
                                FontSize="12"
                                ToolTip="{Binding RefreshResetCreditsText}"
                                IsEnabled="{Binding CanRefreshResetCredits}"
                                Click="RefreshResetCreditsButton_Click" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Grid>
        </Border>

        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,8"
                ToolTip="{Binding MiniResetTooltipText}"
                Visibility="{Binding MiniPanelVisibility}"
                MouseLeftButtonDown="WindowDragArea_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="22" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding ContextMiniText}"
                               Foreground="{Binding ContextRingBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FiveHourMiniText}"
                               Foreground="{Binding FiveHourRingBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="10,0,0,0"
                               Visibility="{Binding FiveHourLimitVisibility}" />
                    <TextBlock Text="{Binding WeeklyMiniText}"
                               Foreground="{Binding WeeklyRingBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="10,0,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="□"
                        Width="20"
                        Height="20"
                        Padding="0"
                        FontSize="13"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="{StaticResource MutedTextBrush}"
                        ToolTip="{Binding ExpandFullModeText}"
                        Click="ExpandButton_Click" />
                <Button Grid.Column="2"
                        Content="●"
                        Width="20"
                        Height="20"
                        Padding="0"
                        FontSize="10"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="{StaticResource MutedTextBrush}"
                        ToolTip="{Binding HideToTrayText}"
                        Click="HideToTrayButton_Click" />
                <Button Grid.Column="3"
                        Content="×"
                        Width="20"
                        Height="20"
                        Padding="0"
                        FontSize="14"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="{StaticResource MutedTextBrush}"
                        Click="CloseButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
